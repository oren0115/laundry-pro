generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  KASIR
  OPERATOR
  KURIR
  CUSTOMER
}

enum ServiceType {
  REGULER
  EXPRESS
  SATUAN
  KILOAN
}

enum OrderStatus {
  DITERIMA
  DICUCI
  DIKERINGKAN
  DISETRIKA
  PACKING
  SELESAI
  DIAMBIL
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum MembershipLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum PickupStatus {
  REQUESTED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum InventoryCategory {
  DETERJEN
  PEWANGI
  PLASTIK
  HANGER
  LAINNYA
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users       User[]
  customers   Customer[]
  orders      Order[]
  inventories Inventory[]
  employees   Employee[]
  pickups     PickupDelivery[]
  expenses    Expense[]

  @@map("branches")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  phone        String?
  role         Role      @default(CUSTOMER)
  branchId     String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  branch         Branch?          @relation(fields: [branchId], references: [id])
  refreshTokens  RefreshToken[]
  customer       Customer?
  ordersCreated  Order[]          @relation("OrderCreatedBy")
  statusUpdates  OrderStatusLog[]
  auditLogs      AuditLog[]
  loginHistories LoginHistory[]
  employee       Employee?
  courierPickups PickupDelivery[] @relation("CourierPickups")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Customer {
  id              String          @id @default(uuid())
  userId          String?         @unique
  branchId        String
  name            String
  phone           String
  email           String?
  address         String?
  membershipLevel MembershipLevel @default(BRONZE)
  points          Int             @default(0)
  totalSpent      Decimal         @default(0) @db.Decimal(12, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  user    User?    @relation(fields: [userId], references: [id])
  branch  Branch   @relation(fields: [branchId], references: [id])
  orders  Order[]
  pickups PickupDelivery[]

  @@map("customers")
}

model Service {
  id          String      @id @default(uuid())
  name        String
  type        ServiceType
  basePrice   Decimal     @db.Decimal(12, 2)
  pricePerKg  Decimal?    @db.Decimal(12, 2)
  expressPct  Decimal     @default(30) @db.Decimal(5, 2)
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders Order[]

  @@map("services")
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  qrCode          String        @unique
  branchId        String
  customerId      String
  serviceId       String
  createdById     String?
  serviceType     ServiceType
  weight          Decimal?      @db.Decimal(8, 2)
  itemCount       Int?
  unitPrice       Decimal       @db.Decimal(12, 2)
  subtotal        Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  surcharge       Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  status          OrderStatus   @default(DITERIMA)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH)
  notes           String?
  photoUrl        String?
  estimatedFinish DateTime?
  finishedAt      DateTime?
  pickedUpAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  branch       Branch           @relation(fields: [branchId], references: [id])
  customer     Customer         @relation(fields: [customerId], references: [id])
  service      Service          @relation(fields: [serviceId], references: [id])
  createdBy    User?            @relation("OrderCreatedBy", fields: [createdById], references: [id])
  statusLogs   OrderStatusLog[]
  pickup       PickupDelivery?

  @@index([branchId, status])
  @@index([customerId])
  @@index([createdAt])
  @@map("orders")
}

model OrderStatusLog {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  updatedBy String?
  createdAt DateTime    @default(now())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  updater User? @relation(fields: [updatedBy], references: [id])

  @@map("order_status_logs")
}

model PickupDelivery {
  id           String       @id @default(uuid())
  orderId      String?      @unique
  customerId   String
  branchId     String
  courierId    String?
  pickupAddress String
  deliveryAddress String?
  scheduledAt  DateTime?
  shippingFee  Decimal      @default(0) @db.Decimal(12, 2)
  status       PickupStatus @default(REQUESTED)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order    Order?   @relation(fields: [orderId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  courier  User?    @relation("CourierPickups", fields: [courierId], references: [id])

  @@map("pickup_deliveries")
}

model Employee {
  id        String   @id @default(uuid())
  userId    String   @unique
  branchId  String
  position  String
  salary    Decimal? @db.Decimal(12, 2)
  hireDate  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  branch      Branch       @relation(fields: [branchId], references: [id])
  shifts      Shift[]
  attendances Attendance[]

  @@map("employees")
}

model Shift {
  id         String   @id @default(uuid())
  employeeId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

model Attendance {
  id         String    @id @default(uuid())
  employeeId String
  date       DateTime  @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendances")
}

model Inventory {
  id           String            @id @default(uuid())
  branchId     String
  name         String
  category     InventoryCategory
  quantity     Decimal           @db.Decimal(10, 2)
  unit         String            @default("pcs")
  minStock     Decimal           @default(10) @db.Decimal(10, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("inventories")
}

model Expense {
  id          String   @id @default(uuid())
  branchId    String
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("expenses")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_histories")
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}

/// Konten halaman publik (landing, promo, hero) — dikelola OWNER
model PublicContentConfig {
  id        String   @id @default("default")
  data      Json
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("public_content_configs")
}
